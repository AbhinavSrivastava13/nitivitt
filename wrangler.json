{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nitivitt",
  "main": ".output/server/index.mjs",
  "compatibility_date": "2024-04-01",
  "workers_dev": false,

  "routes": [
    "nitivitt.in/*"
  ],

  "assets": {
    "directory": ".output/public"
  },

  "compatibility_flags": [
    "nodejs_compat"
  ],

  // SUPABASE_PUBLISHABLE_KEY and GEMINI_API_KEY MUST be set as Cloudflare
  // Worker secrets (Workers & Pages -> nitivitt -> Settings -> Variables),
  // NOT committed here. A placeholder value here would be silently shipped
  // to the browser via SSR and would cause "invalid API key" errors on
  // every Supabase call.
  "vars": {
    "SUPABASE_URL": "https://qviwzgnwlwjjbjoxzitb.supabase.co"
  }
}
