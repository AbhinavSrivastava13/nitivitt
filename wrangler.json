{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nitivitt",
  "main": ".output/server/index.mjs",
  "compatibility_date": "2024-04-01",
  "workers_dev": false,

  "routes": [
    "nitivitt.in/*"
  ],

  "assets": {
    "directory": ".output/public"
  },

  "compatibility_flags": [
    "nodejs_compat"
  ],

  "vars": {
    "SUPABASE_URL": "https://qviwzgnwlwjjbjoxzitb.supabase.co"
  }
}
// NOTE: SUPABASE_PUBLISHABLE_KEY MUST be set as a Cloudflare Worker
// secret (or a real value in `vars` above). Do NOT commit a placeholder —
// a placeholder is silently shipped to the browser and causes
// "invalid API key" on every Supabase call.
//
// Set via dashboard: Workers & Pages → nitivitt → Settings → Variables →
// Add variable → SUPABASE_PUBLISHABLE_KEY = <real publishable/anon key>.
// Or CLI: `wrangler secret put SUPABASE_PUBLISHABLE_KEY`.
